{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/feedback/**",
              "components/navigation/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Manrope))/i]",
        "message": "Font not provided by the design system. Available: Manrope."
      },
      {
        "selector": "JSXOpeningElement[name.name='Alert'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|title|description|onDismiss|isDismissible|actionLabel|onAction|style|key|ref|className|style|children)$/]",
        "message": "<Alert> doesn't accept that prop. Declared props: variant, title, description, onDismiss, isDismissible, actionLabel, onAction, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Alert'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:info|success|warning|error)$/]",
        "message": "<Alert> variant must be one of 'info' | 'success' | 'warning' | 'error'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|initials|alt|size|shape|style|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: src, initials, alt, size, shape, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:xs|sm|md|lg|xl|2xl)$/]",
        "message": "<Avatar> size must be one of 'xs' | 'sm' | 'md' | 'lg' | 'xl' | '2xl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='shape'] > Literal[value!=/^(?:circle|square|rounded)$/]",
        "message": "<Avatar> shape must be one of 'circle' | 'square' | 'rounded'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|variant|size|showDot|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: label, variant, size, showDot, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|info|success|warning|error|neutral)$/]",
        "message": "<Badge> variant must be one of 'primary' | 'info' | 'success' | 'warning' | 'error' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Badge> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|disabled|iconLeft|iconRight|onClick|type|fullWidth|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, disabled, iconLeft, iconRight, onClick, type, fullWidth, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|primary-light|secondary|ghost|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'primary-light' | 'secondary' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:XS|S|M|L|XL|XXL)$/]",
        "message": "<Button> size must be one of 'XS' | 'S' | 'M' | 'L' | 'XL' | 'XXL'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|padding|hasBorder|shadow|radius|background|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, padding, hasBorder, shadow, radius, background, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='padding'] > Literal[value!=/^(?:none|sm|md|lg)$/]",
        "message": "<Card> padding must be one of 'none' | 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='shadow'] > Literal[value!=/^(?:none|xs|sm|md|lg)$/]",
        "message": "<Card> shadow must be one of 'none' | 'xs' | 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='radius'] > Literal[value!=/^(?:sm|md|lg|xl)$/]",
        "message": "<Card> radius must be one of 'sm' | 'md' | 'lg' | 'xl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hintText|placeholder|type|error|disabled|iconLeft|value|onChange|id|name|style|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, hintText, placeholder, type, error, disabled, iconLeft, value, onChange, id, name, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:text|email|password|number|search|url|tel)$/]",
        "message": "<Input> type must be one of 'text' | 'email' | 'password' | 'number' | 'search' | 'url' | 'tel'."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|href|hasDropdown|key|ref|className|style|children)$/]",
        "message": "<NavItem> doesn't accept that prop. Declared props: label, href, hasDropdown."
      },
      {
        "selector": "JSXOpeningElement[name.name='SidebarNavItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|icon|href|isActive|children|onClick|key|ref|className|style|children)$/]",
        "message": "<SidebarNavItem> doesn't accept that prop. Declared props: label, icon, href, isActive, children, onClick."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
