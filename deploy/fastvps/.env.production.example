# Copy this file to the server-local .env file and fill in real values there.
# Do not commit real credentials, webhook URLs, passwords, or session secrets.

APP_NAME=Bitrix Sales Analytics
APP_ENV=production
APP_DEBUG=false
APP_TIMEZONE=Europe/Minsk
APP_ALLOWED_ORIGINS=
APP_DATA_DIR=data
APP_DUCKDB_PATH=

APP_AUTH_ENABLED=true
APP_AUTH_USERNAME=CHANGE_ME
APP_AUTH_PASSWORD=CHANGE_ME
APP_AUTH_SESSION_SECRET=CHANGE_ME_GENERATE_A_STRONG_RANDOM_SECRET
APP_AUTH_SESSION_TTL_SECONDS=86400
APP_AUTH_COOKIE_SECURE=true

BITRIX_WEBHOOK_URL=
BITRIX_CONTACT_TYPE_FIELD=
BITRIX_PAGE_SIZE=50
